# Copy to .env and fill in. .env is gitignored.

# Google Gemini (default operator provider)
GOOGLE_GENERATIVE_AI_API_KEY=

# Backends (these are the defaults; shown for clarity)
VISH_OPERATOR_BACKEND=ai
VISH_CALL_BACKEND=simulated

# --- Dial (only needed when VISH_CALL_BACKEND=dial) ---
# DIAL_API_KEY=sk_live_...
# DIAL_FROM_NUMBER_ID=...
# VISH_DIAL_DRY_RUN=false
